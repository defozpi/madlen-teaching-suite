# Copy to `.env.local` for local dev, or set these in the Vercel dashboard
# (Project Settings -> Environment Variables) for the deployed app.
#
# Nothing here is required: with no key the app runs in DEMO mode using a
# deterministic mock, so the public URL still works end to end.
#
# Backend is auto-selected: OPENAI_API_KEY -> OpenAI-compatible, else
# ANTHROPIC_API_KEY -> Claude, else demo. Force it with LLM_PROVIDER.

# ---------------------------------------------------------------------------
# OPTION A (recommended for low cost): an OpenAI-compatible cheap provider.
# Pick ONE preset below, set OPENAI_API_KEY, and you are done.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# DeepSeek (very cheap, strong quality) - DEFAULTS, so you can leave these unset:
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# Qwen (Alibaba DashScope, international endpoint):
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus            # or qwen-turbo (cheapest)

# Kimi / Moonshot:
# OPENAI_BASE_URL=https://api.moonshot.ai/v1
# OPENAI_MODEL=kimi-k2-0711-preview # or moonshot-v1-8k

# OpenRouter (one key, access DeepSeek/Qwen/Kimi and some FREE models):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=deepseek/deepseek-chat        # or a ":free" model for $0

# ---------------------------------------------------------------------------
# OPTION B: Anthropic Claude (highest quality, pricier). Used only if
# OPENAI_API_KEY is empty.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force a backend regardless of which keys are present.
# LLM_PROVIDER=openai   # openai | anthropic | demo
