# Copy to `.env.local` for local dev, or set these in the Vercel dashboard
# (Project Settings -> Environment Variables) for the deployed app.
#
# Nothing here is strictly required: with no API key the app runs in DEMO mode
# using a deterministic mock, so the public URL still works end to end.

# Anthropic Claude (the default real provider). Leave empty to use demo/mock mode.
ANTHROPIC_API_KEY=
# A capable, cost-friendly default. Swap to claude-haiku-4-5 to spend less,
# or claude-opus-4-8 for the highest quality.
ANTHROPIC_MODEL=claude-sonnet-4-6
